# Twilio credentials — find these in your Twilio Console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The WhatsApp-enabled Twilio number (sandbox or production)
TWILIO_FROM=whatsapp:+14155238886

# Secret key to protect the /run-reminders endpoint
# Choose anything random, e.g. a UUID or long random string
RUN_KEY=choose-a-long-random-secret-here

# Port — Railway sets this automatically, leave as 3000 for local dev
PORT=3000
